# XpressPro FX — Required Environment Variables
# Copy this file to .env and fill in all values before running locally.
# NEVER commit .env — only .env.example is committed.

# ─── Database ─────────────────────────────────────────────────────────────────
# Pooled connection string (used by the running app — e.g. Neon pooler URL)
DATABASE_URL=

# Direct connection string (no -pooler in hostname — used ONLY for prisma migrate deploy)
DIRECT_DATABASE_URL=

# ─── Session ──────────────────────────────────────────────────────────────────
# Generate with: node -e "require('crypto').randomBytes(64).toString('hex')|console.log"
SESSION_SECRET=

# ─── Wallet Encryption ────────────────────────────────────────────────────────
# Generate with: node -e "require('crypto').randomBytes(32).toString('hex')|console.log"
WALLET_ENCRYPTION_KEY=

# ─── Admin Seed Credentials ───────────────────────────────────────────────────
ADMIN_EMAIL=
ADMIN_PASSWORD=

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed production origins
# e.g. https://app.yourdomain.com,https://admin.yourdomain.com
ALLOWED_ORIGINS=

# ─── Email (SendGrid) ─────────────────────────────────────────────────────────
SENDGRID_API_KEY=

# ─── On-chain (Alchemy) ───────────────────────────────────────────────────────
ALCHEMY_API_KEY=

# ─── MoonPay ──────────────────────────────────────────────────────────────────
MOONPAY_API_KEY=
MOONPAY_SECRET_KEY=

# ─── Paystack ─────────────────────────────────────────────────────────────────
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=

# ─── Referral ─────────────────────────────────────────────────────────────────
# USD reward amount for successful referrals (default: 500)
REFERRAL_REWARD_USD=500

# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# ─── Optional / Platform-specific ────────────────────────────────────────────
# API proxy target for local frontend dev (e.g. http://localhost:3000)
API_PROXY_TARGET=
