modules = ["nodejs-20", "web", "bash", "postgresql-16"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
ADMIN_EMAIL = "enwukwerigodspower7@gmail.com,enwukwerigodspower729@yahoo.com"
ADMIN_NOTIFY_EMAIL = "enwukwerigodspower7@gmail.com"
AI_INTEGRATIONS_OPENAI_API_KEY = "_DUMMY_API_KEY_"
AI_INTEGRATIONS_OPENAI_BASE_URL = "http://localhost:1106/modelfarm/openai"
ALLOWED_ORIGINS = "https://xpressprofx.com,https://www.xpressprofx.com"
APP_NAME = "XpressProFx.com"
COREPACK_ENABLE_STRICT = "0"
ENABLE_DEMO_AUTH = "true"
LOG_LEVEL = "info"
